<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ── App-level API key (set from CI/CD or local config; never commit the real value) ── -->
	<key>RancakApiKey</key>
	<string>$(RANCAK_API_KEY)</string>

	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- ── Kamera (barcode scanner) ── -->
	<key>NSCameraUsageDescription</key>
	<string>Dibutuhkan untuk scan barcode produk saat kasir memasukkan item ke keranjang.</string>

	<!-- ── Bluetooth LE (ESC/POS thermal printer) ── -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Dibutuhkan untuk menghubungkan dan mencetak struk via Bluetooth thermal printer.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Dibutuhkan untuk menghubungkan dan mencetak struk via Bluetooth thermal printer.</string>

	<!-- ── Jaringan lokal (TCP/IP printer di LAN) ── -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Dibutuhkan untuk mencetak struk ke printer ESC/POS yang terhubung ke jaringan Wi-Fi/LAN yang sama.</string>

	<!-- ── Background sync (BGTaskScheduler) ── -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>id.rancak.app.sync</string>
	</array>

	<!-- ── Google Sign-In ── -->
	<!-- GIDClientID: iOS Client ID dari Google Cloud Console                    -->
	<!-- Cara mendapatkan: console.cloud.google.com → APIs & Services →          -->
	<!--                   Credentials → Create/pilih OAuth 2.0 Client ID (iOS) -->
	<key>GIDClientID</key>
	<string>YOUR_IOS_CLIENT_ID.apps.googleusercontent.com</string>

	<!-- URL scheme untuk OAuth redirect (REVERSED iOS client ID) -->
	<!-- Contoh: jika client ID = 123456789-abc.apps.googleusercontent.com       -->
	<!--         maka URL scheme = com.googleusercontent.apps.123456789-abc      -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.YOUR_IOS_CLIENT_ID</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
